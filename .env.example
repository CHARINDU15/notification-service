# ============================================
# NOTIFICATION SERVICE - Example Environment Configuration
# ============================================
# Copy this file to .env and update with your actual values

# Application
NODE_ENV=development
PORT=3003
LOG_LEVEL=info

# Supabase Database Configuration
SUPABASE_DB_HOST=your-supabase-host
SUPABASE_DB_PORT=5432
SUPABASE_DB_USER=postgres
SUPABASE_DB_PASSWORD=your-password
SUPABASE_DB_NAME=postgres

# Auth Service Configuration
AUTH_SERVICE_URL=http://localhost:3001

# Database Connection Pool
DB_POOL_MIN=2
DB_POOL_MAX=10

# CORS Configuration
CORS_ORIGIN=*

# Rate Limiting
RATE_LIMIT_WINDOW=900000
RATE_LIMIT_MAX=100

# ============================================
# EMAIL CONFIGURATION (SMTP)
# ============================================
# Gmail Example: https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-specific-password
SMTP_FROM=noreply@parcelpoint.com

# SendGrid Example:
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_USER=apikey
# SMTP_PASSWORD=SG.xxx

# ============================================
# SMS CONFIGURATION (TWILIO)
# ============================================
# Sign up at https://www.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# ============================================
# PUSH NOTIFICATION CONFIGURATION
# ============================================
# OneSignal: https://onesignal.com
# Firebase: https://firebase.google.com
PUSH_NOTIFICATION_PROVIDER=onesignal
PUSH_NOTIFICATION_API_KEY=your-onesignal-api-key

# ============================================
# LOG CONFIGURATION
# ============================================
LOG_PRETTY=false
